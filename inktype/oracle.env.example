# Copy to oracle.env, or run: remagic config inktype
INKTYPE_OPENAI_KEY=
INKTYPE_OPENAI_BASE=https://generativelanguage.googleapis.com/v1beta/openai
INKTYPE_OPENAI_MODEL=gemini-3.1-flash-lite

# Optional pen-up debounce; fast writing is grouped into one recognition call.
# INKTYPE_DEBOUNCE_MS=180

# Riddle's RIDDLE_OPENAI_* variables are accepted as fallbacks.
# Recognition requests reasoning_effort=none, temperature 0, and at most 128
# output tokens (room for providers that still account for hidden tokens).
